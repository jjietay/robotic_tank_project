<?xml version="1.0"?>
<robot name="my_tank">

    <!-- ================================================ -->
    <!--                   BASE LINK                      -->
    <!-- ================================================ -->
    <link name="base_link">
        <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
            <mesh filename="package://tank_description/meshes/full_chassis.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="grey">
            <color rgba="0.5 0.5 0.5 1.0"/>
        </material>
        </visual>

        <collision>
            <origin xyz="0 0 0.0331" rpy="0 0 0"/>
            <geometry>
                <box size="0.26 0.16 0.107"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.5"/>
            <inertia
                ixx="0.003"  ixy="0.0"  ixz="0.0"
                iyy="0.004" iyz="0.0" izz="0.006"/>
        </inertial>
    </link>

    <!-- ================================================ -->
    <!--                  DRIVE WHEELS                    -->
    <!-- ================================================ -->
    <link name="left_drive">
        <visual>
        <geometry>
            <cylinder radius="0.025" length="0.035"/>
        </geometry>
        </visual>
        <collision>
            <geometry><cylinder radius="0.025" length="0.035"/></geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia
                ixx="0.000016" ixy="0.0" ixz="0.0"
                iyy="0.000016" iyz="0.0" izz="0.000016"/>
        </inertial>
    </link>
    <joint name="left_drive_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_drive"/>
        <origin xyz="-0.0925 0.1 0" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="right_drive">
        <visual>
        <geometry>
            <cylinder radius="0.025" length="0.035"/>
        </geometry>
        </visual>
        <collision>
            <geometry><cylinder radius="0.025" length="0.035"/></geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia
                ixx="0.000016" ixy="0.0" ixz="0.0"
                iyy="0.000016" iyz="0.0" izz="0.000016"/>
        </inertial>
    </link>
    <joint name="right_drive_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_drive"/>
        <origin xyz="0.0925 -0.1 0" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>


    <!-- ================================================ -->
    <!--                 BEARING WHEELS                   -->
    <!-- ================================================ -->
    <link name="left_bearing">
        <visual>
        <geometry>
            <cylinder radius="0.025" length="0.033"/>
        </geometry>
        <material name="light_grey">
            <color rgba="0.7 0.7 0.7 1.0"/>
        </material>
        </visual>
        <collision>
            <geometry><cylinder radius="0.025" length="0.033"/></geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia
                ixx="0.000016" ixy="0.0" ixz="0.0"
                iyy="0.000016" iyz="0.0" izz="0.000016"/>
        </inertial>
    </link>
    <joint name="left_bearing_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_bearing"/>
        <origin xyz="0.08 0.1 0" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="right_bearing">
        <visual>
        <geometry>
            <cylinder radius="0.025" length="0.033"/>
        </geometry>
        <material name="light_grey">
            <color rgba="0.7 0.7 0.7 1.0"/>
        </material>
        </visual>
        <collision>
            <geometry><cylinder radius="0.025" length="0.033"/></geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia
                ixx="0.000016" ixy="0.0" ixz="0.0"
                iyy="0.000016" iyz="0.0" izz="0.000016"/>
        </inertial>
    </link>
    <joint name="right_bearing_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_bearing"/>
        <origin xyz="-0.08 -0.1 0" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>


    <!-- ================================================ -->
    <!--     CHASSIS → PLATFORM STANDOFFS (4 per side)    -->
    <!-- ================================================ -->

    <!-- Left side (y = +0.068) -->
    <link name="standoff_l1">
        <visual>
        <geometry><cylinder radius="0.0025" length="0.05"/></geometry>
        <material name="silver"><color rgba="0.75 0.75 0.75 1.0"/></material>
        </visual>
    </link>
    <joint name="standoff_l1_joint" type="fixed">
        <parent link="base_link"/>
        <child link="standoff_l1"/>
        <origin xyz="-0.125 0.068 0.063"/>
    </joint>

    <link name="standoff_l2">
        <visual>
        <geometry><cylinder radius="0.0025" length="0.05"/></geometry>
        <material name="silver"><color rgba="0.75 0.75 0.75 1.0"/></material>
        </visual>
    </link>
    <joint name="standoff_l2_joint" type="fixed">
        <parent link="base_link"/>
        <child link="standoff_l2"/>
        <origin xyz="-0.0605 0.068 0.063"/>
    </joint>

    <link name="standoff_l3">
        <visual>
        <geometry><cylinder radius="0.0025" length="0.05"/></geometry>
        <material name="silver"><color rgba="0.75 0.75 0.75 1.0"/></material>
        </visual>
    </link>
    <joint name="standoff_l3_joint" type="fixed">
        <parent link="base_link"/>
        <child link="standoff_l3"/>
        <origin xyz="0.06 0.068 0.063"/>
    </joint>

    <link name="standoff_l4">
        <visual>
        <geometry><cylinder radius="0.0025" length="0.05"/></geometry>
        <material name="silver"><color rgba="0.75 0.75 0.75 1.0"/></material>
        </visual>
    </link>
    <joint name="standoff_l4_joint" type="fixed">
        <parent link="base_link"/>
        <child link="standoff_l4"/>
        <origin xyz="0.123 0.068 0.063"/>
    </joint>

    <!-- Right side (y = -0.068) -->
    <link name="standoff_r1">
        <visual>
        <geometry><cylinder radius="0.0025" length="0.05"/></geometry>
        <material name="silver"><color rgba="0.75 0.75 0.75 1.0"/></material>
        </visual>
    </link>
    <joint name="standoff_r1_joint" type="fixed">
        <parent link="base_link"/>
        <child link="standoff_r1"/>
        <origin xyz="-0.125 -0.068 0.063"/>
    </joint>

    <link name="standoff_r2">
        <visual>
        <geometry><cylinder radius="0.0025" length="0.05"/></geometry>
        <material name="silver"><color rgba="0.75 0.75 0.75 1.0"/></material>
        </visual>
    </link>
    <joint name="standoff_r2_joint" type="fixed">
        <parent link="base_link"/>
        <child link="standoff_r2"/>
        <origin xyz="-0.0605 -0.068 0.063"/>
    </joint>

    <link name="standoff_r3">
        <visual>
        <geometry><cylinder radius="0.0025" length="0.05"/></geometry>
        <material name="silver"><color rgba="0.75 0.75 0.75 1.0"/></material>
        </visual>
    </link>
    <joint name="standoff_r3_joint" type="fixed">
        <parent link="base_link"/>
        <child link="standoff_r3"/>
        <origin xyz="0.06 -0.068 0.063"/>
    </joint>

    <link name="standoff_r4">
        <visual>
        <geometry><cylinder radius="0.0025" length="0.05"/></geometry>
        <material name="silver"><color rgba="0.75 0.75 0.75 1.0"/></material>
        </visual>
    </link>
    <joint name="standoff_r4_joint" type="fixed">
        <parent link="base_link"/>
        <child link="standoff_r4"/>
        <origin xyz="0.123 -0.068 0.063"/>
    </joint>


    <!-- ================================================ -->
    <!--                    PLATFORM                      -->
    <!-- ================================================ -->
    <link name="platform">
        <visual>
        <geometry>
            <box size="0.257 0.152 0.002"/>
        </geometry>
        <material name="black">
            <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
        </visual>
    </link>
    <joint name="platform_joint" type="fixed">
        <parent link="base_link"/>
        <child link="platform"/>
        <origin xyz="0 0 0.09"/>
    </joint>


    <!-- ================================================ -->
    <!--      PLATFORM → LIDAR STANDOFFS (4 corners)      -->
    <!-- ================================================ -->
    <link name="lidar_standoff_fl">
        <visual>
        <geometry><cylinder radius="0.002" length="0.026"/></geometry>
        <material name="silver"><color rgba="0.75 0.75 0.75 1.0"/></material>
        </visual>
    </link>
    <joint name="lidar_standoff_fl_joint" type="fixed">
        <parent link="platform"/>
        <child link="lidar_standoff_fl"/>
        <origin xyz="0.034 0.032 0.015"/>
    </joint>

    <link name="lidar_standoff_fr">
        <visual>
        <geometry><cylinder radius="0.002" length="0.026"/></geometry>
        <material name="silver"><color rgba="0.75 0.75 0.75 1.0"/></material>
        </visual>
    </link>
    <joint name="lidar_standoff_fr_joint" type="fixed">
        <parent link="platform"/>
        <child link="lidar_standoff_fr"/>
        <origin xyz="0.034 -0.032 0.015"/>
    </joint>

    <link name="lidar_standoff_rl">
        <visual>
        <geometry><cylinder radius="0.002" length="0.026"/></geometry>
        <material name="silver"><color rgba="0.75 0.75 0.75 1.0"/></material>
        </visual>
    </link>
    <joint name="lidar_standoff_rl_joint" type="fixed">
        <parent link="platform"/>
        <child link="lidar_standoff_rl"/>
        <origin xyz="-0.023 0.025 0.015"/>
    </joint>

    <link name="lidar_standoff_rr">
        <visual>
        <geometry><cylinder radius="0.002" length="0.026"/></geometry>
        <material name="silver"><color rgba="0.75 0.75 0.75 1.0"/></material>
        </visual>
    </link>
    <joint name="lidar_standoff_rr_joint" type="fixed">
        <parent link="platform"/>
        <child link="lidar_standoff_rr"/>
        <origin xyz="-0.023 -0.025 0.015"/>
    </joint>


    <!-- ================================================ -->
    <!--                     LIDAR                        -->
    <!-- ================================================ -->
    <link name="lidar_link">
        <visual>
        <origin xyz="0.01176 0 0" rpy="0 0 3.1416"/>
        <geometry>
            <mesh filename="package://tank_description/meshes/ydlidar_x3pro.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="blue">
            <color rgba="0.0 0.0 0.8 1.0"/>
        </material>
        </visual>
    </link>
    <joint name="lidar_joint" type="fixed">
        <parent link="platform"/>
        <child link="lidar_link"/>
        <origin xyz="0 0 0.03"/>
    </joint>


    <!-- ================================================ -->
    <!--                   LEFT TRACK                     -->
    <!-- ================================================ -->
    <link name="track_l_bottom">
        <visual>
        <geometry><box size="0.225 0.045 0.001"/></geometry>
        <material name="dark_rubber"><color rgba="0.15 0.15 0.15 1.0"/></material>
        </visual>
    </link>
    <joint name="track_l_bottom_joint" type="fixed">
        <parent link="base_link"/>
        <child link="track_l_bottom"/>
        <origin xyz="-0.00625 0.103 -0.025"/>
    </joint>

    <link name="track_l_top">
        <visual>
        <geometry><box size="0.225 0.045 0.001"/></geometry>
        <material name="dark_rubber"><color rgba="0.15 0.15 0.15 1.0"/></material>
        </visual>
    </link>
    <joint name="track_l_top_joint" type="fixed">
        <parent link="base_link"/>
        <child link="track_l_top"/>
        <origin xyz="-0.00625 0.103 0.025"/>
    </joint>

    <link name="track_l_rear">
        <visual>
        <geometry><box size="0.001 0.045 0.05"/></geometry>
        <material name="dark_rubber"><color rgba="0.15 0.15 0.15 1.0"/></material>
        </visual>
    </link>
    <joint name="track_l_rear_joint" type="fixed">
        <parent link="base_link"/>
        <child link="track_l_rear"/>
        <origin xyz="-0.118 0.103 0"/>
    </joint>

    <link name="track_l_front">
        <visual>
        <geometry><box size="0.001 0.045 0.05"/></geometry>
        <material name="dark_rubber"><color rgba="0.15 0.15 0.15 1.0"/></material>
        </visual>
    </link>
    <joint name="track_l_front_joint" type="fixed">
        <parent link="base_link"/>
        <child link="track_l_front"/>
        <origin xyz="0.106 0.103 0"/>
    </joint>


    <!-- ================================================ -->
    <!--                   RIGHT TRACK                    -->
    <!-- ================================================ -->
    <link name="track_r_bottom">
        <visual>
        <geometry><box size="0.225 0.045 0.001"/></geometry>
        <material name="dark_rubber"><color rgba="0.15 0.15 0.15 1.0"/></material>
        </visual>
    </link>
    <joint name="track_r_bottom_joint" type="fixed">
        <parent link="base_link"/>
        <child link="track_r_bottom"/>
        <origin xyz="0.00625 -0.103 -0.025"/>
    </joint>

    <link name="track_r_top">
        <visual>
        <geometry><box size="0.225 0.045 0.001"/></geometry>
        <material name="dark_rubber"><color rgba="0.15 0.15 0.15 1.0"/></material>
        </visual>
    </link>
    <joint name="track_r_top_joint" type="fixed">
        <parent link="base_link"/>
        <child link="track_r_top"/>
        <origin xyz="0.00625 -0.103 0.025"/>
    </joint>

    <link name="track_r_rear">
        <visual>
        <geometry><box size="0.001 0.045 0.05"/></geometry>
        <material name="dark_rubber"><color rgba="0.15 0.15 0.15 1.0"/></material>
        </visual>
    </link>
    <joint name="track_r_rear_joint" type="fixed">
        <parent link="base_link"/>
        <child link="track_r_rear"/>
        <origin xyz="0.118 -0.103 0"/>
    </joint>

    <link name="track_r_front">
        <visual>
        <geometry><box size="0.001 0.045 0.05"/></geometry>
        <material name="dark_rubber"><color rgba="0.15 0.15 0.15 1.0"/></material>
        </visual>
    </link>
    <joint name="track_r_front_joint" type="fixed">
        <parent link="base_link"/>
        <child link="track_r_front"/>
        <origin xyz="-0.106 -0.103 0"/>
    </joint>

</robot>